{
  // Tooling scripts run under tsx/Node, not the browser. This config lives next to
  // the scripts so VS Code's TS server associates them with a real project (and
  // therefore loads @types/node) instead of a typeless "inferred project".
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
