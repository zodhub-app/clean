{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZodHub CleanPC",
  "mainBinaryName": "ZodHubCleanPC",
  "version": "0.2.2",
  "identifier": "com.viper.macup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZodHub CleanPC",
        "width": 1200,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 26, "y": 27 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zodhub-app/clean/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzMkNFNDc2M0E0RTFDMgpSV1RDNGFSalI4NHlDZ3Vua2syNmt6eDRrOW5qWFNST1VmeUxmZTZiZVBnN0pTSmtVVk84MUIySQo="
    }
  }
}
